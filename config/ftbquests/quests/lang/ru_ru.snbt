	quest.42BF7B2D2241E6D4.quest_desc: ["&9&lМрачные грибы&r&r можно найти в &0&lГлубокой тьме&r&r. &d&lЦветки хоруса&r&r также можно превратить в &9&lмрачные грибы&r&r"]
	quest.4358A298CABA59D8.quest_desc: ["[ \"Выпадает из \", { \"text\": \"Алюминиевой руды\", \"underlined\": true, \"color\": \"gray\", \"bold\": true, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"7961A2CF4801468B\" } } ]"]
