	quest.39FE25094F4E6455.quest_desc: ["Используйте Shift + правый клик, чтобы привязать предмет к вам. После этого добавьте его в &lмагазин&r, чтобы автоматизировать &lпокупку&r и &lпродажу&r предметов"]
