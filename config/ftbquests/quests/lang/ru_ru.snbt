	quest.50609BAFE7E276DC.quest_desc: ["Может использоваться для нарезки некоторых предметов на &#8B4513&lразделочной доске&r&r"]
	quest.50818EBCACCFA244.quest_desc: ["По ней можно взбираться, а также она используется для многих мультиблочных структур &lImmersive Engineering&r"]
	quest.5096CA9B6F305AFB.quest_desc: ["&2&lНарост Незера&r&r можно найти в &c&lкрепостях Незера&r&r"]
	quest.50BD38056CDC5F59.quest_desc: ["Обожжённый &7&lцементный кирпич&r&r"]
