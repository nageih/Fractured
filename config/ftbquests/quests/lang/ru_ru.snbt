	quest.0EF9A2E31C4BCD93.quest_desc: ["Хранит &lхрононную энергию&r"]
	quest.0F13C3C6FFAA52DC.quest_desc: ["Глубоко в пещерах можно найти &9&lразрушающую воду&r&r. Её также можно добыть с помощью &0&lбуровой вышки&r&r"]
	quest.0F5ED9F96D6D8048.quest_desc: ["Можно прикрепить к установленному &0&lветряному колесу&r&r, чтобы оно вращалось быстрее и производило больше RF "]
	quest.0F64894280306C3D.quest_desc: ["&lЧервей&r можно найти при использовании &lмотыги&r на &lблоках травы&r. Червь поддерживает область 3x3 увлажнённой, а также немного ускоряет рост посевов"]
	quest.0FB30E431E5B8680.quest_desc: ["[ \"Выпадает из \", { \"text\": \"медной руды\", \"underlined\": true, \"color\": \"#ff681f\", \"bold\": true, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"1FD799D3063824F0\" } } ]"]
	quest.103074F46CE1CF6E.quest_desc: [
		"Позволяет обнаруживать глубоко залегающие жидкости в мирах. Работает в пределах чанка!"
