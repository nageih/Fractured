	quest.5A1223F440B9A725.quest_desc: [
		"&0&lЭкскаватор&r&r можно использовать подобно &0&lбуровой вышке&r&r для получения ресурсов из глубоких недр. В каждом измерении есть свои ресурсы, которые может добывать &0&lэкскаватор&r&r."
