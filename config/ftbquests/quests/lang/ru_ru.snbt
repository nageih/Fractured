	quest.5DA1F9B26A151E13.quest_desc: ["Создаётся на &lнефтеперегонном заводе&r, существует несколько способов его получения"]
	quest.5E8367DFAF5747C8.quest_desc: ["&lБумага для чертежей&r используется для создания различных че&lртежей&r, которые используются на &lверстаке инженера&r"]
