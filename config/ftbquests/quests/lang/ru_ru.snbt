	quest.13A26C11AC42F2FF.quest_desc: ["Используется для создания &lлогического пресса&r"]
	quest.13AA5391F7D32AB4.quest_desc: ["&lУкреплённый механический компонент&r"]
	quest.13E6D929EF66D0E6.quest_desc: ["Разрубание &#8B4513&lбрёвен&r&r на &#8B4513&lразделочной доске&r&r даёт &#8B4513&lдревесную кору&r&r и обтёсывает &#8B4513&lбревно&r&r"]
	quest.155A7AA171192C5A.quest_desc: ["Первый &lмир&r, к которому &0&lПустота&r&r даёт доступ, — это &6&lРасколотая пустыня&r&r"]
	quest.1563637174E457E6.quest_desc: ["&7&lМеталлическую пыль&r&r можно получить в &#8B4513&lдоменной печи&r&r"]
	quest.15A0B3BB1FC9B3C9.quest_desc: [
		"Попав на своего летающего &lкита&r в небе с помощью &l/sky create&r, вам нужно приземлиться, и лучший способ сделать это — спрыгнуть!"
		"{@pagebreak}"
