	quest.7B191F638F9C0CED.quest_desc: ["[ \"Выпадает из \", { \"text\": \"железной руды\", \"underlined\": true, \"color\": \"white\", \"bold\": true, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"17E6CA0559A2075A\" } } ]"]
	quest.7BD529298480E2FC.quest_desc: ["Получается при разрушении руды, добытой с помощью &lдобывающей линзы&r"]
	quest.7C0FB00BF8E36170.quest_desc: ["&0&lГрязный уголь&r&r можно поместить в &7&lкоксовую печь&r&r. За раз может обрабатываться до 16 штук"]
