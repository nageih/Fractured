	]
	quest.51E559ACEC3E7EFD.quest_desc: ["&e&lРасколотая пустыня&r&r — крайне &4&lжаркое&r&r место, но там содержатся очень полезные ресурсы, такие как &e&lзолота&r&r, &lсеребро&r, &#8B4513&lникель&r&r и &l&0нефть&r&r"]
