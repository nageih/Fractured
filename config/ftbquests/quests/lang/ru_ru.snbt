	quest.531CAB0179ABDD1D.quest_desc: [
		"[\"В этой сборке используется Ultimine. Удерживание \", {\"keybind\": \"key.ftbultimine\", \"color\": \"aqua\", \"bold\": true }, \" позволит вам ломать несколько блоков одновременно!\"]"
