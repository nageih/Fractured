	quest.428A3130107930B9.quest_desc: ["Может использоваться для ускорения работы &#8B4513&lукреплённой доменной печи&r&r"]
	quest.42A092A9A7A686C7.quest_desc: ["Простую &#9AC0CD&lзаготовку ведра&r,&r необходимо обжечь, чтобы использовать как &7&lведро&r&r"]
